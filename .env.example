# llama-swap connection (required)
LLAMA_SWAP_URL=http://llama-swap:8080
LLAMA_SWAP_API_KEY=any-non-empty-value
ASR_MODEL_NAME=qwen3-asr-1.7b

# Diarization (required for speaker labels)
HF_TOKEN=hf_xxx
PYANNOTE_MODEL=pyannote/speaker-diarization-community-1

# ForcedAligner
FORCED_ALIGNER_MODEL=Qwen/Qwen3-ForcedAligner-0.6B
ALIGNER_DEVICE=cpu

# Processing
DEVICE=cpu
MAX_FILE_SIZE_MB=1000
REQUEST_TIMEOUT=300

# Service
PORT=9000
LOG_LEVEL=info

# Optional: disable diarization entirely (useful for testing)
DISABLE_DIARIZATION=false
